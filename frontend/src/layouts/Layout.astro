---
interface Props {
  title?: string;
}

const { title = "GarSync Dashboard" } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Garmin fitness dashboard" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-surface text-slate-50 font-sans min-h-screen antialiased">
    <div class="max-w-6xl mx-auto p-4 md:p-8">
      <slot />
    </div>
  </body>
</html>
