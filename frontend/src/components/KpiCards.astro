---
---

<div id="kpi-cards" class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
  <div class="kpi-skeleton card p-5 animate-pulse h-28"></div>
  <div class="kpi-skeleton card p-5 animate-pulse h-28"></div>
  <div class="kpi-skeleton card p-5 animate-pulse h-28"></div>
  <div class="kpi-skeleton card p-5 animate-pulse h-28"></div>
</div>

<style>
  .card {
    background-color: #1e293b;
    border: 1px solid #334155;
    border-radius: 0.75rem;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    transition: transform 0.2s;
  }
  .card:hover {
    transform: translateY(-2px);
  }
</style>

<script>
  import { api } from "../lib/api";
  import { formatDuration, formatDistance } from "../lib/format";
  import { $dateRange } from "../lib/stores";

  function createKpiCard(
    borderColor: string,
    label: string,
    value: string,
    valueClass: string,
    subtitle?: string,
    trend?: number, // Percentage change
  ): HTMLDivElement {
    const card = document.createElement("div");
    card.className = `card p-5 border-t-4 ${borderColor} flex flex-col justify-center relative overflow-hidden`;

    const labelEl = document.createElement("div");
    labelEl.className = "text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2";
    labelEl.textContent = label;

    const valueEl = document.createElement("div");
    valueEl.className = `text-3xl md:text-4xl font-bold ${valueClass} truncate`;
    valueEl.textContent = value;

    card.appendChild(labelEl);
    card.appendChild(valueEl);

    if (subtitle || trend !== undefined) {
      const footerEl = document.createElement("div");
      footerEl.className = "flex items-center gap-2 mt-1";

      if (subtitle) {
        const subEl = document.createElement("div");
        subEl.className = "text-xs text-slate-500";
        subEl.textContent = subtitle;
        footerEl.appendChild(subEl);
      }

      if (trend !== undefined && !isNaN(trend) && isFinite(trend) && trend !== 0) {
        const trendEl = document.createElement("div");
        const isPositive = trend > 0;
        // For some metrics (like RHR or Stress), positive is bad (red)
        const isGood = (label.includes("Resting HR") || label.includes("Stress")) ? !isPositive : isPositive;
        
        trendEl.className = `text-[10px] font-bold px-1.5 py-0.5 rounded ${
          isGood ? "bg-emerald-500/20 text-emerald-400" : "bg-rose-500/20 text-rose-400"
        }`;
        trendEl.textContent = `${isPositive ? "↑" : "↓"} ${Math.abs(Math.round(trend))}%`;
        footerEl.appendChild(trendEl);
      }

      card.appendChild(footerEl);
    }

    return card;
  }

  function showSkeletons() {
    const container = document.getElementById("kpi-cards");
    if (!container) return;
    container.innerHTML = `
      <div class="card p-5 animate-pulse h-28 bg-slate-800/50"></div>
      <div class="card p-5 animate-pulse h-28 bg-slate-800/50"></div>
      <div class="card p-5 animate-pulse h-28 bg-slate-800/50"></div>
      <div class="card p-5 animate-pulse h-28 bg-slate-800/50"></div>
    `;
  }

  async function renderKpis() {
    const container = document.getElementById("kpi-cards");
    if (!container) return;

    showSkeletons();

    try {
      const range = $dateRange.get();
      const startDate = new Date(range.start);
      const endDate = new Date(range.end);
      const diffDays = Math.round((endDate.getTime() - startDate.getTime()) / (1000 * 3600 * 24)) + 1;

      const prevEndDate = new Date(startDate);
      prevEndDate.setDate(prevEndDate.getDate() - 1);
      const prevStartDate = new Date(prevEndDate);
      prevStartDate.setDate(prevStartDate.getDate() - diffDays + 1);

      const [current, previous] = await Promise.all([
        api.statsSummary({ start_date: range.start, end_date: range.end }),
        api.statsSummary({ 
          start_date: prevStartDate.toISOString().split("T")[0], 
          end_date: prevEndDate.toISOString().split("T")[0] 
        }),
      ]);

      const calcTrend = (curr: number | null, prev: number | null) => {
        if (!curr || !prev) return undefined;
        return ((curr - prev) / prev) * 100;
      };

      container.replaceChildren(
        createKpiCard(
          "border-t-orange-500",
          "Activities",
          String(current.total_activities),
          "text-white",
          formatDuration(current.total_duration_seconds),
          calcTrend(current.total_activities, previous.total_activities)
        ),
        createKpiCard(
          "border-t-blue-500",
          "Distance",
          formatDistance(current.total_distance_meters),
          "text-white",
          "km",
          calcTrend(current.total_distance_meters, previous.total_distance_meters)
        ),
        createKpiCard(
          "border-t-amber-500",
          "Calories",
          `${Math.round(current.total_calories)}`,
          "text-white",
          "kcal",
          calcTrend(current.total_calories, previous.total_calories)
        ),
        createKpiCard(
          "border-t-rose-500", 
          "Resting HR", 
          current.avg_resting_heart_rate ? `${Math.round(current.avg_resting_heart_rate)}` : "--", 
          "text-white", 
          "bpm avg",
          calcTrend(current.avg_resting_heart_rate, previous.avg_resting_heart_rate)
        ),
      );
    } catch (error) {
      console.error("[KpiCards] Failed to load:", error);
      container.innerHTML = `<div class="col-span-4 text-center text-slate-500 py-4">Failed to load KPIs</div>`;
    }
  }

  $dateRange.subscribe(() => renderKpis());
</script>
