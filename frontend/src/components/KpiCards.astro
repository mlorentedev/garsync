---
---

<div id="kpi-cards" class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
  <div class="kpi-skeleton card p-5 animate-pulse h-28"></div>
  <div class="kpi-skeleton card p-5 animate-pulse h-28"></div>
  <div class="kpi-skeleton card p-5 animate-pulse h-28"></div>
  <div class="kpi-skeleton card p-5 animate-pulse h-28"></div>
</div>

<style>
  .card {
    background-color: #1e293b;
    border: 1px solid #334155;
    border-radius: 0.75rem;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    transition: transform 0.2s;
  }
  .card:hover {
    transform: translateY(-2px);
  }
</style>

<script>
  import { api } from "../lib/api";
  import { formatDuration, formatDistance } from "../lib/format";
  import { $dateRange } from "../lib/stores";

  function createKpiCard(
    borderColor: string,
    label: string,
    value: string,
    valueClass: string,
    subtitle?: string,
  ): HTMLDivElement {
    const card = document.createElement("div");
    card.className = `card p-5 border-t-4 ${borderColor} flex flex-col justify-center`;

    const labelEl = document.createElement("div");
    labelEl.className = "text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2";
    labelEl.textContent = label;

    const valueEl = document.createElement("div");
    valueEl.className = `text-3xl md:text-4xl font-bold ${valueClass} truncate`;
    valueEl.textContent = value;

    card.appendChild(labelEl);
    card.appendChild(valueEl);

    if (subtitle) {
      const subEl = document.createElement("div");
      subEl.className = "text-xs text-slate-500 mt-1";
      subEl.textContent = subtitle;
      card.appendChild(subEl);
    }

    return card;
  }

  async function renderKpis() {
    const container = document.getElementById("kpi-cards");
    if (!container) return;

    try {
      const range = $dateRange.get();
      const [activities, bio] = await Promise.all([
        api.activities({ start_date: range.start, end_date: range.end, limit: 1 }),
        api.biometrics(range.start, range.end),
      ]);

      let latestRHR: number | null = null;
      for (let i = bio.metrics.length - 1; i >= 0; i--) {
        if (bio.metrics[i].resting_heart_rate !== null) {
          latestRHR = bio.metrics[i].resting_heart_rate;
          break;
        }
      }

      const totalActs = activities.total;
      const rhrDisplay = latestRHR !== null ? `${latestRHR}` : "--";

      container.replaceChildren(
        createKpiCard(
          "border-t-orange-500",
          "Activities",
          String(totalActs),
          "text-white",
          "in selected range",
        ),
        createKpiCard(
          "border-t-blue-500",
          "Distance",
          "--",
          "text-white",
        ),
        createKpiCard(
          "border-t-amber-500",
          "Calories",
          "--",
          "text-white",
        ),
        createKpiCard("border-t-rose-500", "Resting HR", rhrDisplay, "text-white", rhrDisplay !== "--" ? "bpm" : ""),
      );

      // Fetch full page to compute distance + calories totals
      if (totalActs > 0) {
        const full = await api.activities({
          start_date: range.start,
          end_date: range.end,
          limit: totalActs,
        });
        let totalDist = 0;
        let totalCal = 0;
        let totalDur = 0;
        for (const a of full.items) {
          if (a.distance_meters !== null) totalDist += a.distance_meters;
          if (a.calories !== null) totalCal += a.calories;
          if (a.duration_seconds !== null) totalDur += a.duration_seconds;
        }
        container.replaceChildren(
          createKpiCard(
            "border-t-orange-500",
            "Activities",
            String(totalActs),
            "text-white",
            formatDuration(totalDur),
          ),
          createKpiCard(
            "border-t-blue-500",
            "Distance",
            formatDistance(totalDist),
            "text-white",
          ),
          createKpiCard(
            "border-t-amber-500",
            "Calories",
            `${Math.round(totalCal)}`,
            "text-white",
            "kcal",
          ),
          createKpiCard("border-t-rose-500", "Resting HR", rhrDisplay, "text-white", rhrDisplay !== "--" ? "bpm" : ""),
        );
      }
    } catch (error) {
      console.error("[KpiCards] Failed to load:", error);
      container.replaceChildren();
      const errDiv = document.createElement("div");
      errDiv.className = "col-span-4 text-center text-slate-500 py-4";
      errDiv.textContent = "Failed to load KPIs";
      container.appendChild(errDiv);
    }
  }

  $dateRange.subscribe(() => renderKpis());
</script>
